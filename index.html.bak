-xl font-display font-bold text-gold">THEMATHINK</span></a><div class="hidden md:flex items-center gap-8"><a href="#home" class="text-gray-400 hover:text-gold transition-colors font-medium">Home</a><a href="#features" class="text-gray-400 hover:text-gold transition-colors font-medium">Features</a><a href="#products" class="text-gray-400 hover:text-gold transition-colors font-medium">Products</a><a href="#pricing" class="text-gray-400 hover:text-gold transition-colors font-medium">Pricing</a></div><div class="hidden md:flex items-center gap-4"><a href="/analyzer" class="text-gold hover:text-gold-light transition-colors">Analyzer</a><button class="btn-glow px-6 py-2 rounded font-display font-bold text-sm">Get Started</button></div><button class="md:hidden text-gold"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu "><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg></button></div></div></nav><section id="home" class="relative min-h-screen flex items-center justify-center pt-20 z-10"><div class="container mx-auto px-6 relative"><div class="text-center max-w-4xl mx-auto" style="opacity:0"><h1 class="text-5xl md:text-7xl font-display font-bold text-gold text-glow mb-4" style="opacity:0;transform:translateY(30px)">THEMATHINK</h1><p class="text-lg md:text-xl text-gray-400 mb-4 font-display tracking-widest" style="opacity:0;transform:translateY(30px)">THE MACHINE THAT THINKS</p><div class="mb-8" style="opacity:0;transform:translateY(30px)"><p class="text-xl md:text-2xl text-gray-300 italic mb-2">&quot;We don&#x27;t give answers.</p><p class="text-xl md:text-2xl text-gray-300 italic mb-2">We help you find your own.&quot;</p></div><p class="text-lg text-gray-500 mb-12" style="opacity:0;transform:translateY(30px)">Pain points are not problems to be solved.<br/>They are questions waiting to be asked.</p><div class="flex flex-col sm:flex-row items-center justify-center gap-4" style="opacity:0;transform:translateY(30px)"><a href="/analyzer" class="btn-glow px-8 py-4 rounded-lg font-display font-bold text-lg flex items-center gap-2">Try Now<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right "><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></a><a href="#features" class="px-8 py-4 rounded-lg font-display font-bold text-gray-400 hover:text-gold border border-void-light hover:border-gold transition-all">Learn More</a></div><div class="grid grid-cols-3 gap-6 mt-20 max-w-2xl mx-auto" style="opacity:0;transform:translateY(30px)"><div class="bg-void-light/50 border border-gold/20 rounded-lg p-4"><div class="text-3xl font-display font-bold text-gold">8,291</div><div class="text-sm text-gray-500">Pain Points</div></div><div class="bg-void-light/50 border border-gold/20 rounded-lg p-4"><div class="text-3xl font-display font-bold text-matrix">1,337</div><div class="text-sm text-gray-500">Active Users</div></div><div class="bg-void-light/50 border border-gold/20 rounded-lg p-4"><div class="text-3xl font-display font-bold text-gold">47</div><div class="text-sm text-gray-500">Predictions</div></div></div></div></div><div class="absolute bottom-10 left-1/2 -translate-x-1/2"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right text-gold/50 rotate-90"><path d="m9 18 6-6-6-6"></path></svg></div></section><section id="features" class="py-24 relative z-10"><div class="container mx-auto px-6"><div class="text-center mb-16" style="opacity:0;transform:translateY(20px)"><h2 class="text-4xl font-display font-bold text-gold mb-4">Features</h2><p class="text-gray-400">Discover pain points, predict trends, validate ideas</p></div><div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6"><div class="bg-void-light border border-gold/20 rounded-lg p-6 card-hover" style="opacity:0;transform:translateY(20px)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap w-10 h-10 mb-4 text-gold"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg><h3 class="text-lg font-display font-bold text-white mb-2">Pain Point Live</h3><p class="text-gray-400 text-sm">Real-time WebSocket streaming of pain points, like watching a live stream</p></div><div class="bg-void-light border border-gold/20 rounded-lg p-6 card-hover" style="opacity:0;transform:translateY(20px)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe w-10 h-10 mb-4 text-matrix"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg><h3 class="text-lg font-display font-bold text-white mb-2">Global Heat Map</h3><p class="text-gray-400 text-sm">Visualize pain point distribution worldwide, filter by country/region</p></div><div class="bg-void-light border border-gold/20 rounded-lg p-6 card-hover" style="opacity:0;transform:translateY(20px)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-brain w-10 h-10 mb-4 text-gold"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"></path><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"></path></svg><h3 class="text-lg font-display font-bold text-white mb-2">AI Prediction</h3><p class="text-gray-400 text-sm">Predict trending pain points in the next 7 days, stay ahead</p></div><div class="bg-void-light border border-gold/20 rounded-lg p-6 card-hover" style="opacity:0;transform:translateY(20px)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users w-10 h-10 mb-4 text-matrix"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg><h3 class="text-lg font-display font-bold text-white mb-2">Community Validation</h3><p class="text-gray-400 text-sm">User voting to verify pain point authenticity</p></div><div class="bg-void-light border border-gold/20 rounded-lg p-6 card-hover" style="opacity:0;transform:translateY(20px)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock w-10 h-10 mb-4 text-gold"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg><h3 class="text-lg font-display font-bold text-white mb-2">Timeline</h3><p class="text-gray-400 text-sm">Pain point evolution history, trace the origin</p></div><div class="bg-void-light border border-gold/20 rounded-lg p-6 card-hover" style="opacity:0;transform:translateY(20px)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stro